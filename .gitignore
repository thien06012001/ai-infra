# Node.js
node_modules/
package-lock.json

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment secrets (never commit)
.env
.env.*
!.env.example

# Claude Code per-machine settings (local permission allowlist, etc.)
.claude/settings.local.json

# Knowledge base runtime state (regenerated by scripts/hooks)
scripts/state.json
scripts/last-flush.json
scripts/flush.log
scripts/compile.log
scripts/session-flush-*
scripts/flush-context-*

# Reports: lint output, infra-run logs, captured transcripts (all regenerated).
# The frozen probe set reports/kb-probes.md is re-included so it stays tracked.
reports/*
!reports/kb-probes.md
reports/*.jsonl
run.log

# KB search index — rebuilt deterministically by scripts/index.py (SQLite bytes).
reports/.search-index.db
reports/.search-index.db-*

# codegraph symbol index — machine-local SQLite, rebuilt by `codegraph init` + its watcher.
.codegraph/

# Timestamped backups
*.bak
